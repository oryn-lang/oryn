fn add(a: int, b: int) -> int {
    rn a + b
}

fn greet(name: String) -> String {
    rn "hello, {name}"
}

fn shout(message: String) {
    print("!!! {message} !!!")
}

fn fib(n: int) -> int {
    if n < 2 {
        rn n
    }
    rn fib(n - 1) + fib(n - 2)
}

print(greet("Oryn"))
print("add(2, 3) = {add(2, 3)}")
shout("dragons")
for i in 0..10 {
    print("fib({i}) = {fib(i)}")
}
