// Closure with a single captured local, called in a tight loop.
// Tests MakeClosure + CallValue + capture copy overhead on every
// invocation. Compare against Lua's native closure support.

fn make_adder(n: int) -> fn(int) -> int {
    return fn(x: int) -> int { return x + n }
}

let add10 = make_adder(10)
let total = 0
let i = 0

while i < 20000 {
    total = add10(i)
    i = i + 1
}

print(total)
